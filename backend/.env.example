# Copy this file to .env for local development and fill in real values.
# NEVER commit the real .env file -- it is already in .gitignore.
# In production (Render/Railway/etc.), set these as environment
# variables / secrets in the host's dashboard instead of a .env file.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional tuning
TACTICS_MAX_FRAMES=8
TACTICS_MAX_EVENTS_IN_PROMPT=120
